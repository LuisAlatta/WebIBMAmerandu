---

<footer class="bg-footer-bg text-white py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 items-start">
      <!-- Brand -->
      <div>
        <img
          src="/images/logo-blanco.png"
          alt="Amerandú — Club de lectura y pensamiento latinoamericano"
          class="h-16 w-auto mb-2"
          loading="lazy"
        />
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-3">Contacto</h4>
        <a
          href="mailto:ameranduclub@gmail.com"
          class="text-white/70 hover:text-amarillo transition-colors text-sm block"
        >
          ameranduclub@gmail.com
        </a>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-semibold text-white mb-3">Seguinos</h4>
        <a
          href="https://linkedin.com/company/amerandu"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn de Amerandú"
          class="inline-flex items-center gap-2 text-white/70 hover:text-amarillo transition-colors text-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-5 h-5"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 mt-10 pt-6">
      <p class="text-white/50 text-sm text-center">
        &copy; 2026 Amerandú. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
